{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": ".",
    "outDir": "./dist",

    "allowJs": true,
    "checkJs": false,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": false,
    "skipLibCheck": true,

    "types": ["node"]
  },
  "include": ["backend"]
}